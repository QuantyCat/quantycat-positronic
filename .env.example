# Path to the shared data directory.
# Contains: datasets/, checkpoints/, norm_stats/, logs/
# Default when unset: ~/quantycat-data
#
# Local development — default works, nothing to set.
#
# Cloud VM — set to your mounted data volume, e.g.:
#   export QUANTYCAT_DATA_HOME=/mnt/data
#
# export QUANTYCAT_DATA_HOME=~/quantycat-data
